<div class="min-h-screen flex flex-col items-center justify-center bg-gray-100 px-4 py-8 space-y-8 w-full">
  <div class="bg-white p-8 rounded-xl shadow-lg w-full max-w-4xl">
    <h1 class="text-2xl font-semibold text-center mb-6">Your Weather Forecast</h1>
    <%= form_with(method: :get, url: root_url, local: true) do %>
      <div class="mb-4">
        <%=
          text_field_tag(
            :address,
            retrieve_address(@geocoded, @address),
            class: "w-full text-lg px-5 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500",
            placeholder: "Enter address",
            required: true
          )
        %>
      </div>

      <div>
        <%= submit_tag("Get Forecast",
          class: "w-full bg-blue-600 text-white text-lg py-3 px-5 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
        ) %>
      </div>
    <% end %>
  </div>

  <% if @forecast.present? %>
    <div class="w-full max-w-4xl rounded-xl shadow-lg text-white bg-gradient-to-br from-blue-500 via-blue-400 to-blue-300 p-6">
      <h2 class="text-xl font-semibold text-center mb-6"><%= retrieve_address(@geocoded, @address) %></h2>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center space-x-6">
          <img src="<%= @forecast.icon_url %>" alt="Weather icon" class="w-24 h-24">
          <div>
            <p class="text-5xl font-bold"><%= @forecast.temperature %>°C</p>
            <p class="capitalize text-lg"><%= @forecast.description %></p>
          </div>
        </div>
        <div class="text-lg space-y-1 text-center sm:text-right">
          <p><strong>High:</strong> <%= @forecast.temperature_max %>°C</p>
          <p><strong>Low:</strong> <%= @forecast.temperature_min %>°C</p>
        </div>
      </div>
    </div>
  <% end %>
</div>
