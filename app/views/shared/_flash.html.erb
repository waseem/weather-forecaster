<div class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 w-full max-w-2xl px-4">
  <% flash.each do |type, message| %>
    <% color_classes = case type.to_sym
          when :notice then "bg-green-100 border-green-400 text-green-700"
          when :alert  then "bg-red-100 border-red-400 text-red-700"
          else              "bg-blue-100 border-blue-400 text-blue-700"
        end %>

    <div class="flash-auto-hide border-l-4 p-4 mb-4 rounded shadow-sm <%= color_classes %> flex items-center justify-between">
      <span><%= message %></span>
      <button type="button" onclick="this.parentElement.remove()" class="font-bold ml-4">×</button>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".flash-auto-hide").forEach(el => {
      setTimeout(() => el.remove(), 5000);
    });
  });
</script>
